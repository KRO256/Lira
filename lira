#!/usr/bin/env luajit

function trim(s)
    return s:match("^%s*(.-)%s*$")
end

function eval(expr)

    expr = expr:gsub("%f[%a]True%f[%A]", "true")
    expr = expr:gsub("%f[%a]False%f[%A]", "false")

    if expr:match('^".*"$') then
        return expr:sub(2,-2)
    end

    expr = expr:gsub("(%a+)%((.-)%)", function(name,arg)

        if funcs[name] then

            local f = funcs[name]

            local old = vars[f.arg]

            vars[f.arg] = eval(arg)

            local result = run(f.code)

            vars[f.arg] = old

            if result and result.type == "return" then
                return result.value
            end

            return ""
        end

        return name.."("..arg..")"
    end)

    expr = expr:gsub("%a+", function(v)

        if vars[v] ~= nil then

            if type(vars[v]) == "string" then
                return '"' .. vars[v] .. '"'
            else
                return vars[v]
            end

        end

        return v
    end)

    if expr:find('"') then
        expr = expr:gsub("%+","..")
    end

    local f, err = load("return "..expr, "expr", "t", {})

    if not f then
        print("Invalid expression: "..expr)
        return nil
    end

    local ok, result = pcall(f)

    if not ok then
        print("Runtime error: "..result)
        return nil
    end

    return result
end

vars = {}
funcs = {}

function run(code)

    local lines = {}
    for l in code:gmatch("[^\r\n]+") do
        table.insert(lines, trim(l))
    end

    local i = 1

    while i <= #lines do
        local line = lines[i]

        line = line:gsub("@.*","")
        line = trim(line)

        if line == "" then
            i = i + 1
            goto continue
        end

        local fname,arg = line:match("^set (%a+)%((%a+)%)")
        if fname then

            local block = {}
            i = i + 1

            while lines[i] and trim(lines[i]) ~= "end" do
                table.insert(block, lines[i])
                i = i + 1
            end

            funcs[fname] = {
                arg = arg,
                code = table.concat(block,"\n")
            }

        elseif line:match("^if ") then
    
        local cond = line:match("^if (.+)")
        local block = {}
        local elseblock = {}
        local inelse = false
        local depth = 1
    
        i = i + 1
    
        while i <= #lines do
            local l = trim(lines[i])
    
            if l:match("^if ") or l:match("^while ") then
                depth = depth + 1
            elseif l == "end" then
                depth = depth - 1
                if depth == 0 then
                    break
                end
            elseif l == "else" and depth == 1 then
                inelse = true
                i = i + 1
            else
                if inelse then
                    table.insert(elseblock, lines[i])
                else
                    table.insert(block, lines[i])
                end
                i = i + 1
            end
        end
    
        if depth ~= 0 then
            error("missing end")
        end
    
        local result
    
        if eval(cond) then
            result = run(table.concat(block,"\n"))
        else
            result = run(table.concat(elseblock,"\n"))
        end
    
        if result == "break" then
            return "break"
        end
    
        if result and result.type == "return" then
            return result
        end
            
        elseif line:match("^while ") then
    
        local cond = line:match("^while (.+)")
        local block = {}
        local depth = 1
    
        i = i + 1
    
        while i <= #lines do
            local l = trim(lines[i])
    
            if l:match("^while ") or l:match("^if ") then
                depth = depth + 1
    
            elseif l == "end" then
                depth = depth - 1
                if depth == 0 then
                    break
                end
            end
    
            table.insert(block, lines[i])
            i = i + 1
        end
    
        if depth ~= 0 then
            error("missing end")
        end
    
        local blockcode = table.concat(block,"\n")
    
        while eval(cond) do
            local result = run(blockcode)
    
            if result == "break" then
                break
            end
    
            if result and result.type == "return" then
                return result
            end
        end

        elseif line == "break" then
            return "break"

        elseif line:match("^return ") then
            local expr = line:sub(8)
            return { type="return", value=eval(expr) }
        
        elseif line:match("^input ") then
            local var = line:match("^input (%a+)")
            vars[var] = io.read()

        elseif line:match("^let ") then
            local name,value = line:match("^let (%a+) = (.+)")
            vars[name] = eval(value)

        elseif line:sub(1,6) == "print " then
            local expr = line:sub(7)
            print(eval(expr))

        else
            local call,arg = line:match("^(%a+)%((.+)%)")

            if call and funcs[call] then

                local f = funcs[call]

                local old = vars[f.arg]

                vars[f.arg] = eval(arg)

                local result = run(f.code)

                vars[f.arg] = old

                if result and result.type == "return" then
                    return result
                end
            end
        end

        i = i + 1
        ::continue::
    end
end

local filename = arg[1]

if not filename then
    io.stderr:write("Error: no input file\n")
    os.exit(1)
end

local file = io.open(filename,"r")

if not file then
    io.stderr:write("Error: file not found: "..filename.."\n")
    os.exit(1)
end

local code = file:read("*all")
file:close()

local ok, err = pcall(function()
    run(code)
end)

if not ok then
    if tostring(err):match("interrupted") then
        io.stderr:write("\nExecution stopped (Ctrl+C)\n")
        os.exit(130)
    else
        io.stderr:write("Runtime error: "..tostring(err).."\n")
        os.exit(1)
    end
end